# ── Supabase (the Elenos website's project; portal data lives in the `portal` schema) ──
# Project URL and keys from Supabase → Project Settings → API.
# Remember to add `portal` to Settings → API → Exposed schemas.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY. Bypasses RLS. Used for creating client
# accounts and sending invites. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──
# Base URL used to build invite links (and in production, the live domain).
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Notifications (Discord) ──
# Discord incoming webhook URL (Server Settings → Integrations → Webhooks).
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
# Shared secret the DB webhook sends to /api/notify; must match the value in
# supabase/migrations/0002_notifications.sql AND 0005_client_notifications.sql.
NOTIFY_WEBHOOK_SECRET=generate-a-long-random-string

# ── Notifications (Email via Resend) — SERVER ONLY; optional ──
# Emails clients when their ticket is replied to / changes status, and emails
# staff on new client tickets. Leave unset to no-op (no emails sent).
# API key from resend.com → API Keys. Sender domain must be verified in Resend.
RESEND_API_KEY=re_...
NOTIFY_EMAIL_FROM=Elenos <notify@elenos.ai>
# Base URL used for links inside notification emails. Optional; defaults to
# https://portal.elenos.ai.
PORTAL_URL=https://portal.elenos.ai
