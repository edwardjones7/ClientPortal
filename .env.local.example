# ── Supabase (shared project with the Elenos admin dashboard) ──
# Project URL and keys from Supabase → Project Settings → API.
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service-role key — SERVER ONLY. Bypasses RLS. Used for creating client
# accounts and sending invites. Never expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── App ──
# Base URL used in invite emails (redirect target after invite acceptance).
NEXT_PUBLIC_SITE_URL=http://localhost:3000
